rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restaurantes e garagens — leitura pública, escrita autenticada
    match /restaurants/{slug} {
      allow read: if true;
      allow write: if request.auth != null;

      match /data/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Contratos — somente autenticados
    match /contracts/{slug} {
      allow read, write: if request.auth != null;
    }

    // Configurações (tokens OAuth, etc.) — somente autenticados
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // Usuários — somente autenticados
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
